# ==========================================================================
# Visual Vault — Backend (.env)
# Copia este archivo a ".env" y rellena los valores. NO subas el .env real.
# ==========================================================================

# --- Seguridad / JWT ---
# Clave secreta para firmar los tokens JWT. Genera una larga y aleatoria, p.ej:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria

# Correo que será administrador automáticamente (Ctrl+Shift+A, borrar/editar pines)
ADMIN_EMAIL=tucorreo@ejemplo.com

# --- CORS (orígenes del frontend permitidos, separados por coma) ---
# En local puedes omitirlo (usa localhost por defecto).
# En producción pon la URL pública del frontend (tu EC2 / dominio):
#   CORS_ORIGINS=http://TU_IP_PUBLICA_EC2,https://tudominio.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- AWS S3 + Rekognition (subida y moderación de imágenes) ---
AWS_ACCESS_KEY_ID=tu-access-key
AWS_SECRET_ACCESS_KEY=tu-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=visual-vault-4to-semestre

# --- Correo SMTP (códigos de verificación, bienvenida, alertas) ---
# Para Gmail usa una "contraseña de aplicación", no la normal.
MAIL_USERNAME=tucorreo@gmail.com
MAIL_PASSWORD=tu-contraseña-de-aplicacion
MAIL_FROM=tucorreo@gmail.com
MAIL_PORT=465
MAIL_SERVER=smtp.gmail.com

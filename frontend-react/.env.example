# ==========================================================================
# Visual Vault — Frontend (.env)
# Copia a ".env". Vite "hornea" estas variables en el BUILD (no en runtime),
# así que define la URL del backend ANTES de hacer "npm run build".
# ==========================================================================

# URL pública del backend (incluye /api/v1).
# Local:
#   VITE_API_URL=http://localhost:8000/api/v1
# Producción (tu EC2 / dominio):
#   VITE_API_URL=http://TU_IP_PUBLICA_EC2:8000/api/v1
VITE_API_URL=http://localhost:8000/api/v1

# --- Microsoft SSO (MSAL) — opcional, solo si usas login con Outlook ---
# Tu propia app de Azure (App registrations → Application (client) ID).
# Si lo dejas vacío usa el clientId por defecto del proyecto.
VITE_MSAL_CLIENT_ID=

# A dónde vuelve Microsoft tras el login. Si lo dejas vacío usa el origen actual
# (window.location.origin). Ese MISMO origen debe estar registrado como
# "Redirect URI" (tipo SPA) en el portal de Azure de tu app.
#   VITE_MSAL_REDIRECT_URI=http://TU_IP_PUBLICA_EC2
VITE_MSAL_REDIRECT_URI=
